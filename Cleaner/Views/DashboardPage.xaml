<Page x:Class="Cleaner.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:conv="clr-namespace:Cleaner.Converters"
      xmlns:Primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1200"
      Background="{DynamicResource WindowBackground}">

    <Page.Resources>
        <conv:ScaleConverter x:Key="ScaleConv"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30">
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" />
            <TextBlock Text="Resumen general del sistema" FontSize="14"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,4,0,20" />

            <!-- Health Score Card -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="25" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Width="120" Height="120">
                        <Ellipse Stroke="{DynamicResource CardBorder}" StrokeThickness="8"
                                 Width="120" Height="120"/>
                        <Ellipse Stroke="{DynamicResource HealthGreen}" StrokeThickness="8"
                                 Width="120" Height="120"
                                 StrokeDashArray="282.7" StrokeDashOffset="22.6"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding HealthScore}" FontSize="36"
                                       FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding HealthStatus}" FontSize="12"
                                       Foreground="{DynamicResource HealthGreen}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="25,0,0,0">
                        <TextBlock Text="Salud del Sistema" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Tu PC está funcionando de manera óptima" FontSize="13"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CPU" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding CpuUsageText}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="RAM" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding RamUsageText}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Disco Libre" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="{Binding WasteSpace}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Optimizar Todo" Command="{Binding RunCleanCommand}"
                                Style="{StaticResource ActionButton}"
                                Background="{DynamicResource AccentColor}" Foreground="White"
                                Padding="16,8"
                                HorizontalAlignment="Left" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Stats Cards Row (5 cards now) -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CPU Card -->
                <Border Grid.Column="0" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="16">
                    <StackPanel>
                        <TextBlock Text="🖥️" FontSize="20"/>
                        <TextBlock Text="CPU" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,2"/>
                        <TextBlock Text="{Binding CpuUsageText}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <ProgressBar Value="{Binding CpuUsage}" Maximum="100" Height="3"
                                     Foreground="{DynamicResource AccentColor}"
                                     Background="{DynamicResource CardBorder}" Margin="0,6,0,0"
                                     BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- RAM Card -->
                <Border Grid.Column="1" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="16" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="💾" FontSize="20"/>
                        <TextBlock Text="RAM" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,2"/>
                        <TextBlock Text="{Binding RamUsageText}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="{Binding RamAvailableText}" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                        <ProgressBar Value="{Binding RamUsage}" Maximum="100" Height="3"
                                     Foreground="{DynamicResource HealthGreen}"
                                     Background="{DynamicResource CardBorder}" Margin="0,6,0,0"
                                     BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- Temperature Card -->
                <Border Grid.Column="2" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="16" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🌡️" FontSize="20"/>
                        <TextBlock Text="Temperatura" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,2"/>
                        <TextBlock Text="{Binding TemperatureText}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Normal" FontSize="10" Foreground="{DynamicResource HealthGreen}"/>
                    </StackPanel>
                </Border>

                <!-- Uptime Card -->
                <Border Grid.Column="3" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="16" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="⏱️" FontSize="20"/>
                        <TextBlock Text="Tiempo Activo" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,2"/>
                        <TextBlock Text="{Binding SystemUptime}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Desde último reinicio" FontSize="10" Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Optimization Charts (auto-width bars) -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Historial de Optimización" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Últimos 40 períodos de monitoreo" FontSize="12"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,20"/>

                    <!-- CPU Chart -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CPU" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{DynamicResource WindowBackground}"
                                CornerRadius="6" Padding="4" Height="36">
                            <ItemsControl ItemsSource="{Binding CpuHistory}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Primitives:UniformGrid Columns="60"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="1,0,1,0" VerticalAlignment="Bottom"
                                                Background="{DynamicResource AccentColor}"
                                                Height="{Binding Converter={StaticResource ScaleConv}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>

                    <!-- RAM Chart -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="RAM" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource HealthGreen}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{DynamicResource WindowBackground}"
                                CornerRadius="6" Padding="4" Height="36">
                            <ItemsControl ItemsSource="{Binding RamHistory}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Primitives:UniformGrid Columns="60"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="1,0,1,0" VerticalAlignment="Bottom"
                                                Background="{DynamicResource HealthGreen}"
                                                Height="{Binding Converter={StaticResource ScaleConv}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>

                    <!-- Health Chart -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Salud" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource HealthGreen}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{DynamicResource WindowBackground}"
                                CornerRadius="6" Padding="4" Height="36">
                            <ItemsControl ItemsSource="{Binding HealthHistory}" Opacity="0.7">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Primitives:UniformGrid Columns="60"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="1,0,1,0" VerticalAlignment="Bottom"
                                                Background="{DynamicResource HealthGreen}"
                                                Height="{Binding Converter={StaticResource ScaleConv}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>

                    <!-- Temp Chart -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Temp" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource HealthRed}" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Background="{DynamicResource WindowBackground}"
                                CornerRadius="6" Padding="4" Height="36">
                            <ItemsControl ItemsSource="{Binding TempHistory}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Primitives:UniformGrid Columns="60"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="1,0,1,0" VerticalAlignment="Bottom"
                                                Background="{DynamicResource HealthRed}"
                                                Height="{Binding Converter={StaticResource ScaleConv}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Footer - Powered by Agdala 2026 -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Powered by Agdala 2026"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="1" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,4,0,12">
                        <Hyperlink NavigateUri="mailto:agdala.sv@gmail.com"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource TextSecondary}">
                            Contacto: agdala.sv@gmail.com
                        </Hyperlink>
                    </TextBlock>

                    <!-- BTC Wallet -->
                    <Border Grid.Row="2" Background="{DynamicResource WindowBackground}"
                            CornerRadius="8" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding BtcAddress}"
                                       FontSize="13" FontFamily="Consolas"
                                       Foreground="{DynamicResource HealthYellow}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Copiar"
                                    Style="{StaticResource ActionButton}"
                                    Background="{DynamicResource AccentColor}" Foreground="White"
                                    Padding="12,6" Margin="8,0,0,0"
                                    FontSize="12"
                                    Command="{Binding CopyBtcCommand}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Rectangle Height="20" Opacity="0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
