<Page x:Class="Cleaner.Views.AppManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:conv="clr-namespace:Cleaner.Converters"
      mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000"
      Background="{DynamicResource WindowBackground}">

    <Page.Resources>
        <conv:AppIconConverter x:Key="AppIcon"/>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Gestor de Aplicaciones" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Administra las aplicaciones instaladas en tu equipo"
                       FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                CornerRadius="14" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Selecciona una app para desinstalar" FontSize="11"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="🔍  Escanear" Command="{Binding ScanCommand}"
                        Style="{StaticResource ActionButton}"
                        Background="{DynamicResource AccentColor}" Foreground="White"
                        Padding="20,10" Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="🗑️  Desinstalar" Command="{Binding UninstallCommand}"
                        Style="{StaticResource ActionButton}"
                        Background="{DynamicResource HealthRed}" Foreground="White"
                        Padding="20,10"/>
            </Grid>
        </Border>

        <!-- App count badge -->
        <Border Grid.Row="2" Background="Transparent" Margin="0,0,0,10">
            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}">
                <Run Text="Aplicaciones instaladas:"/>
                <Run Text="{Binding InstalledApps.Count}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
            </TextBlock>
        </Border>

        <!-- App List -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                CornerRadius="14" Padding="6">
            <ListView ItemsSource="{Binding InstalledApps}"
                      SelectedItem="{Binding SelectedApp}"
                      Background="Transparent" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" Margin="6,3" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- App icon -->
                                <Grid Width="36" Height="36" VerticalAlignment="Center">
                                    <Border CornerRadius="6" Background="{DynamicResource AccentColor}">
                                        <TextBlock Text="{Binding Initial}" FontSize="16" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Image Source="{Binding DisplayIcon, Converter={StaticResource AppIcon}}"
                                           Width="36" Height="36" Stretch="Uniform"/>
                                </Grid>

                                <!-- App info -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Publisher}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text=" · " FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding Version}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Size badge -->
                                <Border Grid.Column="2" Background="{DynamicResource WindowBackground}"
                                        CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SizeFormatted}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentColor}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
