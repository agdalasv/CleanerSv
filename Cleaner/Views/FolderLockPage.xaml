<Page x:Class="Cleaner.Views.FolderLockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:conv="clr-namespace:Cleaner.Converters"
      mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000"
      Background="{DynamicResource WindowBackground}">

    <Page.Resources>
        <conv:BoolToLockIconConverter x:Key="BoolToLockIcon"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30">
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Bloqueo de Carpetas" FontSize="28" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Protege tus archivos con contraseña" FontSize="14"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="25" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="80" Height="80" CornerRadius="40"
                            Background="{DynamicResource CardBorder}">
                        <TextBlock Text="{Binding IsLocked, Converter={StaticResource BoolToLockIcon}}"
                                   FontSize="36" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusMessage}" FontSize="15" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding VaultPath}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Configurar Contraseña" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Mínimo 6 caracteres (letras, números o símbolos)"
                               FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,4,0,16"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="8"
                                Background="{DynamicResource WindowBackground}"
                                BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1">
                            <PasswordBox x:Name="PasswordBox"
                                         PasswordChanged="PasswordBox_Changed"
                                         FontSize="14" Padding="10,8"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource TextPrimary}"/>
                        </Border>
                        <Border Grid.Column="1" CornerRadius="8" Margin="10,0,0,0"
                                Background="{DynamicResource WindowBackground}"
                                BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1">
                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         PasswordChanged="ConfirmPasswordBox_Changed"
                                         FontSize="14" Padding="10,8"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource TextPrimary}"/>
                        </Border>
                    </Grid>
                    <Button Content="Proteger y Bloquear Carpeta"
                            Command="{Binding SetPasswordCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="{DynamicResource AccentColor}" Foreground="White"
                            Padding="20,10" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Desbloquear Carpeta" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Ingresa la contraseña para acceder a la carpeta protegida"
                               FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,4,0,16"/>
                    <Border CornerRadius="8"
                            Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1">
                        <PasswordBox x:Name="UnlockPasswordBox"
                                     PasswordChanged="UnlockPasswordBox_Changed"
                                     FontSize="14" Padding="10,8"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimary}"/>
                    </Border>
                    <Button Content="Desbloquear" Command="{Binding UnlockCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="{DynamicResource HealthGreen}" Foreground="White"
                            Padding="20,10" HorizontalAlignment="Left" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Acciones" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Abre la carpeta o vuélvela a bloquear"
                               FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,4,0,16"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Bloquear Carpeta" Command="{Binding LockCommand}"
                                Style="{StaticResource ActionButton}"
                                Background="{DynamicResource HealthRed}" Foreground="White"
                                Padding="20,10" Margin="0,0,10,0"/>
                        <Button Content="Abrir Carpeta" Command="{Binding OpenFolderCommand}"
                                Style="{StaticResource ActionButton}"
                                Background="{DynamicResource AccentColor}" Foreground="White"
                                Padding="20,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>

