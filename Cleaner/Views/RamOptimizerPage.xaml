<Page x:Class="Cleaner.Views.RamOptimizerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000"
      Background="{DynamicResource WindowBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30">
            <TextBlock Text="Optimizador de RAM" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Libera y optimiza la memoria del sistema" FontSize="14"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,20"/>

            <!-- RAM Usage Ring -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="25" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Width="140" Height="140">
                        <Ellipse Stroke="{DynamicResource CardBorder}" StrokeThickness="10" Width="140" Height="140"/>
                        <Ellipse Stroke="{DynamicResource HealthGreen}" StrokeThickness="10" Width="140" Height="140"
                                 StrokeDashArray="395.8" StrokeDashOffset="79.2"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding RamUsageText}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"/>
                            <TextBlock Text="usado" FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Column="1" Margin="25,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding AvailableText}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Disponible / Total" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="⚡ Optimizar RAM" Command="{Binding OptimizeCommand}"
                                    Style="{StaticResource ActionButton}"
                                    Background="{DynamicResource AccentColor}" Foreground="White"
                                    Padding="20,10" Margin="0,0,10,0"/>
                            <Button Content="🎮 Modo Gaming" Command="{Binding StartGamingModeCommand}"
                                    Style="{StaticResource ActionButton}"
                                    Background="#7C4DFF" Foreground="White"
                                    Padding="20,10"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Top Processes -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Procesos con mayor consumo de RAM" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{DynamicResource CardBorder}" Margin="0,12"/>
                    <ItemsControl ItemsSource="{Binding TopProcesses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="6" Height="6" CornerRadius="3"
                                            Background="{DynamicResource AccentColor}" Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding MemoryMB, StringFormat='{}{0:F1} MB'}"
                                               FontSize="13" Foreground="{DynamicResource HealthGreen}"
                                               FontFamily="Consolas"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Status -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20">
                <StackPanel>
                    <TextBlock Text="Estado" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
