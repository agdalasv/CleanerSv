<Page x:Class="Cleaner.Views.SystemMonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000"
      Background="{DynamicResource WindowBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30">
            <TextBlock Text="Monitor del Sistema" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Rendimiento en tiempo real" FontSize="14"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,20"/>

            <!-- Real-time Gauges -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- CPU -->
                <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="20">
                    <StackPanel>
                        <TextBlock Text="CPU" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <ProgressBar Value="{Binding Cpu}" Maximum="100" Height="6" Margin="0,12,0,6"
                                     Foreground="{DynamicResource AccentColor}"
                                     Background="{DynamicResource CardBorder}"
                                     BorderThickness="0"/>
                        <TextBlock Text="{Binding CpuText}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>

                <!-- RAM -->
                <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="20" Margin="15,0,0,0">
                    <StackPanel>
                        <TextBlock Text="RAM" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <ProgressBar Value="{Binding Ram}" Maximum="100" Height="6" Margin="0,12,0,6"
                                     Foreground="{DynamicResource HealthGreen}"
                                     Background="{DynamicResource CardBorder}"
                                     BorderThickness="0"/>
                        <TextBlock Text="{Binding RamText}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>

                <!-- GPU -->
                <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="20" Margin="15,0,0,0">
                    <StackPanel>
                        <TextBlock Text="GPU" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <ProgressBar Value="{Binding Gpu}" Maximum="100" Height="6" Margin="0,12,0,6"
                                     Foreground="#E040FB"
                                     Background="{DynamicResource CardBorder}"
                                     BorderThickness="0"/>
                        <TextBlock Text="{Binding GpuText}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>

                <!-- Disk -->
                <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Disco" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <ProgressBar Value="{Binding Disk}" Maximum="100" Height="6" Margin="0,12,0,6"
                                     Foreground="#FF9800"
                                     Background="{DynamicResource CardBorder}"
                                     BorderThickness="0"/>
                        <TextBlock Text="{Binding DiskText}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>

                <!-- Temperature -->
                <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="20" Margin="15,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Temperatura" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="{Binding TemperatureText}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,12,0,6"/>
                        <TextBlock Text="CPU / Sistema" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Process List -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Procesos Activos" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,10">
                            <Run Text="{Binding ActiveProcesses}"/><Run Text=" procesos en ejecución"/>
                        </TextBlock>
                        <TextBlock Text="{Binding TopProcesses}" FontSize="12"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontFamily="Consolas" LineHeight="18"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                        <TextBlock Text="Batería" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding BatteryStatus}" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource HealthGreen}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
