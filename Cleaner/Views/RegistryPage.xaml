<Page x:Class="Cleaner.Views.RegistryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Cleaner.Views"
      mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000"
      Background="{DynamicResource WindowBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30">
            <TextBlock Text="Registro de Windows" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Limpia y repara el registro del sistema" FontSize="14"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,20"/>

            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Estado" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="🔍 Escanear" Command="{Binding ScanCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="{DynamicResource AccentColor}" Foreground="White"
                            Padding="20,10" Margin="0,0,10,0"/>
                    <Button Grid.Column="2" Content="🔧 Reparar" Command="{Binding RepairCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="#FF9800" Foreground="White"
                            Padding="20,10" Margin="0,0,10,0"/>
                    <Button Grid.Column="3" Content="💾 Respaldo" Command="{Binding BackupCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}"
                            Padding="20,10"/>
                </Grid>
            </Border>

            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="5">
                <StackPanel>
                    <TextBlock Text="Problemas encontrados" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="15,10"/>
                    <ItemsControl ItemsSource="{Binding Issues}" Margin="0,5,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WindowBackground}"
                                        CornerRadius="8" Margin="10,3" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding Selected}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding Type}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                VerticalAlignment="Center"
                                                Background="{Binding Severity, Converter={x:Static local:SeverityConverters.Instance}}">
                                            <TextBlock Text="{Binding Severity}" FontSize="10" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
