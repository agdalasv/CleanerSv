<Page x:Class="Cleaner.Views.DiskCleanupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Cleaner.Views"
      mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000"
      Background="{DynamicResource WindowBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30">
            <TextBlock Text="Limpieza de Archivos" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Elimina archivos temporales y libera espacio" FontSize="14"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,20"/>

            <!-- Action Bar -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Espacio Recuperable" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding TotalSize}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource HealthGreen}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="30,0,0,0">
                        <TextBlock Text="Estado" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="🔍 Escanear" Command="{Binding ScanCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="{DynamicResource AccentColor}" Foreground="White"
                            Padding="20,10" Margin="0,0,10,0"
                            IsEnabled="{Binding IsScanning, Converter={x:Static local:BooleanConverters.Invert}}"/>
                    <Button Grid.Column="3" Content="🧹 Limpiar" Command="{Binding CleanCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="#F44336" Foreground="White"
                            Padding="20,10"/>
                </Grid>
            </Border>

            <!-- Progress -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20" Margin="0,0,0,20"
                    Visibility="{Binding IsScanning, Converter={x:Static local:BooleanConverters.ToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Escaneando..." FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,10,0,0"
                                 Foreground="{DynamicResource AccentColor}"
                                 Background="{DynamicResource CardBorder}"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>

            <!-- Items List -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="5">
                <StackPanel>
                    <TextBlock Text="Elementos encontrados" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="15,10"/>
                    <ItemsControl ItemsSource="{Binding Items}" Margin="0,5,0,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WindowBackground}"
                                        CornerRadius="8" Margin="10,3" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding Selected}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding Category}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding SizeFormatted}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center" Margin="10,0"/>
                                        <Border Grid.Column="3" Background="#4CAF50" CornerRadius="4"
                                                Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Risk}" FontSize="10"
                                                       Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
