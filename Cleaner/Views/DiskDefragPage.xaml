<Page x:Class="Cleaner.Views.DiskDefragPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Cleaner.Views"
      mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000"
      Background="{DynamicResource WindowBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30">
            <TextBlock Text="Desfragmentador de Disco" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Optimiza unidades HDD y SSD" FontSize="14"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,20"/>

            <!-- Drive Info -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="16" Padding="25" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Width="120" Height="120">
                        <Ellipse Stroke="{DynamicResource CardBorder}" StrokeThickness="8" Width="120" Height="120"/>
                        <Ellipse Stroke="#FF9800" StrokeThickness="8" Width="120" Height="120"
                                 StrokeDashArray="282.7" StrokeDashOffset="56.5"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding FragmentationText}" FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Column="1" Margin="25,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Unidad C:" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="{Binding DriveHealth}" FontSize="14"
                                   Foreground="{DynamicResource HealthGreen}" Margin="0,4,0,8"/>
                        <Border Background="{DynamicResource WindowBackground}" CornerRadius="6"
                                Padding="8,4" HorizontalAlignment="Left">
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}">
                                <Run Text="Tipo: "/>
                                <Run Text="{Binding IsSsd, StringFormat='{}{0}'}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimary}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Actions -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Acciones" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="📊 Analizar" Command="{Binding AnalyzeCommand}"
                                Style="{StaticResource ActionButton}"
                                Background="{DynamicResource AccentColor}" Foreground="White"
                                Padding="16,10" Margin="0,0,10,0"/>
                        <Button Content="⚡ Desfragmentar" Command="{Binding OptimizeCommand}"
                                Style="{StaticResource ActionButton}"
                                Background="#FF9800" Foreground="White"
                                Padding="16,10" Margin="0,0,10,0"
                                IsEnabled="{Binding IsSsd, Converter={x:Static local:BooleanConverters.Invert}}"/>
                        <Button Content="✨ TRIM" Command="{Binding TrimCommand}"
                                Style="{StaticResource ActionButton}"
                                Background="#4CAF50" Foreground="White"
                                Padding="16,10"
                                IsEnabled="{Binding IsSsd}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Visual Block Map -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20">
                <StackPanel>
                    <TextBlock Text="Mapa de Bloques del Disco" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
                    <Grid Height="120">
                        <ItemsControl ItemsSource="{Binding BlockColors, FallbackValue={x:Null}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="40" Rows="10"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Rectangle Fill="{Binding}" Margin="1" RadiusX="2" RadiusY="2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="#4CAF50" Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                        <TextBlock Grid.Column="1" Text="Optimizado" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,20,0"/>
                        <Rectangle Grid.Column="2" Fill="#FF9800" Width="12" Height="12" RadiusX="2" RadiusY="2" Margin="0,0,4,0"/>
                        <TextBlock Grid.Column="3" Text="Fragmentado" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
