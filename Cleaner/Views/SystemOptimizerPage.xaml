<Page x:Class="Cleaner.Views.SystemOptimizerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000"
      Background="{DynamicResource WindowBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30">
            <TextBlock Text="Optimización del Sistema" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Mejora el rendimiento global de Windows" FontSize="14"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,20"/>

            <!-- Stats -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🚀" FontSize="28"/>
                        <TextBlock Text="Programas Inicio" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding StartupPrograms}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="20" Margin="15,0,0,0">
                    <StackPanel>
                        <TextBlock Text="⚙️" FontSize="28"/>
                        <TextBlock Text="Servicios Innecesarios" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding UnnecessaryServices}" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="20" Margin="15,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🎯" FontSize="28"/>
                        <TextBlock Text="Estado" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentColor}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Startup Programs List -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Programas que se ejecutan al inicio" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
                    <ListView ItemsSource="{Binding StartupList}"
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="300">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WindowBackground}"
                                        CornerRadius="8" Margin="0,3" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" CornerRadius="6"
                                                Background="{DynamicResource HealthYellow}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="🚀" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding Command}" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" Background="{DynamicResource CardBorder}"
                                                CornerRadius="4" Padding="6,3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Source}" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Unnecessary Services List -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Servicios innecesarios" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
                    <ListView ItemsSource="{Binding ServiceList}"
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="300">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WindowBackground}"
                                        CornerRadius="8" Margin="0,3" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" CornerRadius="6"
                                                Background="{DynamicResource HealthRed}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="⚙️" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" Background="{DynamicResource CardBorder}"
                                                CornerRadius="4" Padding="6,3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StartType}" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondary}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Optimization Options -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Opciones de Optimización" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>
                    <CheckBox Content="Modo Turbo - Priorizar rendimiento máximo" IsChecked="{Binding TurboMode}"
                              Margin="0,0,0,10" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                    <CheckBox Content="Modo Gaming - Desactivar servicios en segundo plano" IsChecked="{Binding GamingMode}"
                              Margin="0,0,0,10" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                    <CheckBox Content="Optimización de Red - Mejorar latencia y velocidad" IsChecked="{Binding NetworkOpt}"
                              Margin="0,0,0,15" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="📊 Analizar" Command="{Binding AnalyzeCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="{DynamicResource CardBorder}" Foreground="{DynamicResource TextPrimary}"
                            Padding="20,10" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="⚡ Optimizar Todo" Command="{Binding OptimizeCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="{DynamicResource AccentColor}" Foreground="White"
                            Padding="20,10" HorizontalAlignment="Left"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
