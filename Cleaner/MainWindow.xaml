<Window x:Class="Cleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cleaner Sv" Height="650" Width="1000"
        MinHeight="600" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Icon="logo.png"
        Background="{DynamicResource WindowBackground}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Border Background="{DynamicResource WindowBackground}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,16,16,20"
                                MouseLeftButtonDown="SidebarHeader_MouseDown" Cursor="Hand">
                        <Image Source="logo.png" Width="22" Height="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Cleaner Sv" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CardBorder}">
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding ToggleThemeCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ThemeIcon}" Margin="16,0,6,0"/>
                                <TextBlock Text="Cambiar tema"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="MODULOS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="16,0,0,6"/>
                            <Button Content="📊  Dashboard" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="Dashboard"/>
                            <Button Content="🗑️  Limpieza" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="DiskCleanup"/>
                            <Button Content="📋  Registro" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="Registry"/>
                            <Button Content="💾  RAM" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="RamOptimizer"/>
                            <Button Content="💿  Desfragmentar" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="DiskDefrag"/>
                            <Button Content="🔍  Chequeo" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="DiskCheck"/>
                            <Button Content="⚡  Optimizar" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="SystemOptimizer"/>
                            <Button Content="📈  Monitor" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="SystemMonitor"/>
                            <Button Content="📦  Apps" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="AppManager"/>
                            <Button Content="🛡️  Backup" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="Backup"/>
                            <Button Content="🔐  Carpeta Segura" Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateCommand}" CommandParameter="FolderLock"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header bar (drag + buttons) -->
                <Border Grid.Row="0" Background="{DynamicResource SidebarBackground}" Padding="12,0"
                        MouseLeftButtonDown="Header_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button x:Name="MinBtn" Width="46" Height="30"
                                    Style="{StaticResource TitleBarBtnStyle}"
                                    Click="Minimize_Click">
                                <Path Data="M0,0 L10,0" Stroke="{DynamicResource TextSecondary}"
                                      StrokeThickness="1.2" SnapsToDevicePixels="True"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                            <Button x:Name="MaxBtn" Width="46" Height="30"
                                    Style="{StaticResource TitleBarBtnStyle}"
                                    Click="Maximize_Click">
                                <Path Data="M0,0 L8,0 L8,8 L0,8 Z" Stroke="{DynamicResource TextSecondary}"
                                      StrokeThickness="1.2" SnapsToDevicePixels="True"
                                      Width="10" Height="10"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                            <Button x:Name="CloseBtn" Width="46" Height="30"
                                    Style="{StaticResource CloseBtnStyle}"
                                    Click="Close_Click">
                                <Path Data="M0,0 L8,8 M8,0 L0,8" Stroke="{DynamicResource TextSecondary}"
                                      StrokeThickness="1.2" SnapsToDevicePixels="True"
                                      Width="10" Height="10"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page Content -->
                <Frame Grid.Row="1" Content="{Binding CurrentPage}"
                       NavigationUIVisibility="Hidden"
                       Focusable="False"
                       Background="Transparent"/>
            </Grid>
        </Grid>
    </Border>
</Window>
